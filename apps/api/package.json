{
  "name": "@aiva/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "db:generate-auth": "pnpm exec better-auth generate --config src/auth/config.ts --output src/db/auth-schema.ts --yes",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "dev": "tsx watch src/index.ts",
    "format": "biome format --write src drizzle.config.ts",
    "lint": "biome check src drizzle.config.ts",
    "start": "node dist/index.js",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible-v5": "npm:@ai-sdk/openai-compatible@1.0.32",
    "@aiva/shared": "workspace:*",
    "@hono/node-server": "^1.14.4",
    "@mastra/core": "^1.10.0",
    "@mastra/loggers": "^1.0.2",
    "@mastra/memory": "^1.6.1",
    "@mastra/observability": "^1.3.1",
    "@mastra/pg": "^1.7.2",
    "better-auth": "^1.5.4",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.6",
    "hono": "^4.11.9",
    "postgres": "^3.4.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@types/node": "^24.6.0",
    "drizzle-kit": "^0.31.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
