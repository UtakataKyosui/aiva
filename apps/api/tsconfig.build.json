{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": false,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@aiva/shared": ["../../packages/shared/dist/index.d.ts"],
      "@aiva/shared/*": ["../../packages/shared/dist/*"]
    }
  },
  "include": ["src"]
}
