{
  "name": "@aiva/web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rsbuild build",
    "dev": "rsbuild dev --open false",
    "format": "biome format --write src tests rsbuild.config.ts rstest.config.ts",
    "lint": "biome check src tests rsbuild.config.ts rstest.config.ts",
    "preview": "rsbuild preview",
    "start": "rsbuild preview --host 0.0.0.0 --port ${PORT:-3000}",
    "test": "rstest"
  },
  "dependencies": {
    "@aiva/shared": "workspace:*",
    "@fontsource-variable/geist": "^5.2.8",
    "@tanstack/react-router": "^1.166.2",
    "better-auth": "^1.5.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@rsbuild/core": "^1.7.1",
    "@rsbuild/plugin-react": "^1.4.2",
    "@rstest/core": "^0.7.8",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^20.0.11",
    "typescript": "^5.9.3"
  }
}
