{
  "name": "aiva-workspace",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "build": "moon run :build",
    "dev": "moon run :dev",
    "dev:api": "pnpm --filter @aiva/api dev",
    "dev:web": "pnpm --filter @aiva/web dev",
    "format": "moon run :format",
    "lint": "moon run :lint",
    "test": "moon run :test",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:migrate": "pnpm --filter @aiva/api db:migrate",
    "db:studio": "pnpm --filter @aiva/api db:studio"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@moonrepo/cli": "^1.40.3",
    "typescript": "^5.9.3"
  }
}
